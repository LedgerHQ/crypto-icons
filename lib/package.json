{
  "name": "@ledgerhq/crypto-icons",
  "version": "2.0.3",
  "description": "Crypto icons by Ledger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/crypto-icons"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "react-native": "dist/index.native.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/index.native.d.ts",
      "import": "./dist/index.native.mjs",
      "require": "./dist/index.native.js",
      "default": "./dist/index.native.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build-storybook:native": "storybook build -c .storybook-rn",
    "build-storybook:react": "storybook build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check:mapping": "node scripts/checkMapping.js",
    "compress": "bash ../compress/compress.sh",
    "generate:index:help": "echo \"Generates the index.json file from the '_record.json' file\"",
    "generate:index": "tsx scripts/generate_index.ts",
    "knip": "knip",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "storybook-generate": "sb-rn-get-stories",
    "storybook:native": "storybook dev -p 6007 -c .storybook-rn",
    "storybook:react": "storybook dev -p 6006",
    "test:watch": "jest --watch",
    "test": "jest",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "devDependencies": {
    "@ledgerhq/lumen-design-core": "^0.1.13",
    "@ledgerhq/lumen-ui-react": "^0.1.31",
    "@ledgerhq/lumen-ui-rnative": "^0.1.32",
    "@ledgerhq/wallet-api-client": "^1.5.9",
    "@storybook/addon-controls": "8.2.6",
    "@storybook/addon-essentials": "8.2.6",
    "@storybook/addon-react-native-web": "^0.0.21",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.4",
    "@storybook/react": "^8.2.6",
    "@storybook/react-webpack5": "^8.2.6",
    "@tailwindcss/postcss": "4.1.18",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonfile": "^6.1.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.0.0",
    "eslint": "^8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsonfile": "^6.2.0",
    "knip": "^6.12.2",
    "msw": "1.3.3",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-native-web": "^0.20.0",
    "storybook": "^8.2.6",
    "style-loader": "^4.0.0",
    "tailwindcss": "4.1.18",
    "ts-jest": "^29.2.3",
    "tsdown": "^0.22.0",
    "tsx": "^4.20.5",
    "typescript": "^5.5.4",
    "whatwg-fetch": "^3.6.20",
    "zod": "^4.1.9",
    "zopflipng-bin": "^7.1.0"
  },
  "peerDependencies": {
    "@ledgerhq/lumen-design-core": ">=0.1.13",
    "@ledgerhq/lumen-ui-react": ">=0.1.31",
    "@ledgerhq/lumen-ui-rnative": ">=0.1.32",
    "react": ">=18",
    "react-dom": ">=18",
    "react-native": ">=0.70"
  },
  "peerDependenciesMeta": {
    "@ledgerhq/lumen-design-core": {
      "optional": true
    },
    "@ledgerhq/lumen-ui-react": {
      "optional": true
    },
    "@ledgerhq/lumen-ui-rnative": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "packageManager": "pnpm@9.6.0"
}
